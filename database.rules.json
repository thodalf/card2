{
  "rules": {
    // ── Per-user data — decks, collection, economy, stats, tombstones,
    // pseudo mirror. Nothing here is read by any user other than its owner
    // anywhere in the app, so it's fully private.
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Username uniqueness index (usernames/{normalizedPseudo}: uid).
    // Read must stay open to any authenticated user — sendFriendRequest()
    // resolves a typed-in pseudo to a uid before anyone is "friends" yet.
    // Write is restricted so a slot can only be claimed while empty, and
    // only ever touched afterwards by the uid that already owns it
    // (covers both claimUsername's re-claim and its release-old-slot step).
    "usernames": {
      "$pseudo": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || (data.exists() && data.val() === auth.uid))"
      }
    },

    // ── Friends — bidirectional. Accepting a request (respondFriendRequest)
    // and deleting an account (deleteAccountData) both need to write the
    // *other* person's friends/{otherUid}/{myUid} entry, so write allows
    // either side of the pair, not just the list owner. Only the owner can
    // read their own list. Shape is validated to keep a compromised/rogue
    // client from stuffing oversized junk into someone else's list.
    "friends": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)",
          ".validate": "newData.hasChildren(['pseudo','since']) && newData.child('pseudo').isString() && newData.child('pseudo').val().length <= 12 && newData.child('since').isNumber()"
        }
      }
    },

    // ── Friend request mailbox — sender writes into the recipient's
    // mailbox; recipient clears it on accept/decline. Only the recipient can
    // read the whole mailbox, but sendFriendRequest() also needs to read back
    // its own single entry (friendRequests/{toUid}/{fromUid}) to detect an
    // already-pending request before re-sending — without this nested rule
    // that read hits the parent's owner-only rule and throws PERMISSION_DENIED
    // for the sender, which is the "permission denied on add friend" bug.
    "friendRequests": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$fromUid": {
          ".read": "auth != null && auth.uid === $fromUid",
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $fromUid)",
          ".validate": "newData.hasChildren(['fromPseudo','at']) && newData.child('fromPseudo').isString() && newData.child('fromPseudo').val().length <= 12 && newData.child('at').isNumber()"
        }
      }
    },

    // ── Notifications — any authenticated user can drop a NEW notification
    // into someone else's mailbox (friend request, challenge, match
    // result); deleting an existing entry is allowed for anyone too (the
    // owner's own subscribeNotifications() prunes past-cap entries — see
    // firebase.js), but *rewriting* one's content is owner-only. Only the
    // owner reads their own mailbox. .validate constrains payload shape so
    // an authenticated attacker can't spam arbitrary/oversized junk into a
    // stranger's mailbox, can't spoof who a notification is "from" (fromUid/
    // byUid must match the actual writer), and — since a 'challenge'
    // notification carries a "join this room" action — can only be sent to
    // an existing friend, not blasted at arbitrary strangers.
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$pushId": {
          ".write": "auth != null && (!data.exists() || auth.uid === $uid || newData.val() === null)",
          ".validate": "newData.val() === null || (newData.hasChildren(['type','at']) && newData.child('at').isNumber() && newData.child('type').val().matches(/^(friend_request|friend_accept|challenge|match_result|level_up)$/) && (!newData.hasChild('fromUid') || newData.child('fromUid').val() === auth.uid) && (!newData.hasChild('byUid') || newData.child('byUid').val() === auth.uid) && (!newData.hasChild('fromPseudo') || newData.child('fromPseudo').val().length <= 12) && (!newData.hasChild('byPseudo') || newData.child('byPseudo').val().length <= 12) && (!newData.hasChild('code') || newData.child('code').val().matches(/^[A-HJ-NP-Z2-9]{6}$/)) && (newData.child('type').val() !== 'challenge' || root.child('friends').child($uid).child(auth.uid).exists()))"
        }
      }
    },

    // ── Online match rooms and matchmaking queue. Deliberately NOT uid-gated:
    // anonymous (logged-out) online play is a supported feature, and a room
    // is a shared secret (the 6-character code) rather than an owned
    // resource — anyone who has the code is meant to be able to join it.
    // The practical mitigation is the code space (32^6 ≈ 1.07B combinations)
    // and each room's short lifetime, not an auth check. If anonymous play
    // is ever dropped, tighten this to hostUid/guestUid-based access.
    //
    // .read/.write are scoped to $code (not the bare "rooms"/"matchmaking"
    // collections) specifically so a client can never dump/enumerate every
    // active room or the whole matchmaking queue in one request — the app
    // itself never reads those bare paths, only rooms/{code} and
    // matchmaking/waiting|results/{id}, so this is free hardening.
    // .validate rejects malformed/garbage payloads (wrong shape, a room code
    // outside genRoomCode()'s alphabet) — cheap insurance against a script
    // flooding the database with junk nodes instead of real game rooms.
    "rooms": {
      "$code": {
        ".read": true,
        ".write": "$code.matches(/^[A-HJ-NP-Z2-9]{6}$/)",
        ".validate": "newData.hasChildren(['state','player2Joined','createdAt']) && newData.child('player2Joined').isBoolean() && newData.child('createdAt').isNumber()"
      }
    },
    "matchmaking": {
      "waiting": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id','ts']) && newData.child('id').isString() && newData.child('ts').isNumber()"
      },
      "results": {
        "$id": {
          ".read": true,
          ".write": true,
          ".validate": "newData.hasChildren(['code','at']) && newData.child('code').val().matches(/^[A-HJ-NP-Z2-9]{6}$/) && newData.child('at').isNumber()"
        }
      }
    },

    // Deny everything else by default.
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
